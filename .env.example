# Telegram API credentials (https://my.telegram.org/apps)
API_ID=
API_HASH=

# String session (optional — if empty, creates new session file)
STRING_SESSION=

# Owner Telegram ID (who can use bot commands)
OWNER_ID=5457847440

# Web server port (default: 8080)
PORT=8080

# Have I Been Pwned API key (optional, for !check_email)
HIBP_API_KEY=

# Media download directory (default: ./media)
MEDIA_DIR=./media
